# Required
OPENAI_API_KEY=sk-...

# Required for quality mode (WhisperX diarization)
# Get token at https://huggingface.co/settings/tokens
# Accept terms at https://huggingface.co/pyannote/speaker-diarization-3.1
# Accept terms at https://huggingface.co/pyannote/segmentation-3.0
HF_TOKEN=hf_...

# Language: "en" or "es"
LANGUAGE=en

# STT mode: "fast" or "quality"
STT_MODE=fast

# Whisper models
WHISPER_MODEL=small
WHISPER_FAST_MODEL=base

# OpenAI
OPENAI_MODEL=gpt-4o-mini

# TTS voices
TTS_VOICE_EN=af_heart
TTS_VOICE_ES=ef_dora
TTS_SPEED=1.0

# VAD
VAD_THRESHOLD=0.5
SILENCE_DURATION_MS=800

# Server
HOST=0.0.0.0
PORT=8000
